   "source": "\"\"\"\neval_from_csv.py\n\n    RESULT_CSV = \"atc_rag_results_20260515_074351.csv\"\n    GOLD_CSV   = \"atco2_gold_clean.csv\"\n    exec(open(\"eval_from_csv.py\").read())\n\"\"\"\n\nimport subprocess, sys\n\ndef _ensure(*pkgs):\n    for pkg in pkgs:\n        try:\n            __import__(pkg.split('[')[0].replace('-', '_'))\n        except ImportError:\n            subprocess.check_call([sys.executable, '-m', 'pip', 'install', '-q', pkg])\n\n_ensure('pandas', 'numpy', 'jiwer', 'scikit-learn', 'matplotlib', 'editdistance')\n\nimport re\nimport numpy as np\nimport pandas as pd\nfrom jiwer import wer as _wer\nfrom sklearn.metrics import precision_recall_fscore_support\nimport editdistance\nimport matplotlib\nmatplotlib.use('Agg')\nimport matplotlib.pyplot as plt\nfrom datetime import datetime\n\nGOLD_CSV   = \"atco2_gold_clean.csv\"                   # gold annotation CSV\n\nres  = pd.read_csv(RESULT_CSV)\ngold = pd.read_csv(GOLD_CSV)\n\ngold['file_key'] = gold['file'].str.replace('.xml', '', regex=False).str.strip()\n\ngold_agg = (\n    gold.sort_values(['file_key', 'segment_id'])\n    .groupby('file_key', sort=False)\n    .agg(\n        n_segs      =('segment_id', 'count'),\n        gold_clean  =('gold_clean_text', lambda s: ' '.join(s.astype(str))),\n        gold_tagged =('gold_text',       lambda s: ' '.join(s.astype(str))),\n    )\n    .reset_index()\n)\n\nprint(gold_agg['n_segs'].value_counts().sort_index().to_string())\nprint()\n\ndf = res.merge(gold_agg[['file_key','n_segs','gold_clean','gold_tagged']],\n               on='file_key', how='left')\n\nno_gold = df['gold_clean'].isnull().sum()\n\n_subword = re.compile(r'\\s*##\\w*')\n_space   = re.compile(r'\\s+')\n_tag     = re.compile(r'\\[/?#\\w+\\]')\n\ndef clean(text: str) -> str:\n    text = _subword.sub('', str(text))\n    return _space.sub(' ', text).strip().lower()\n\ndef safe_wer(ref, hyp) -> float | None:\n    try:\n        r, h = clean(ref), clean(hyp)\n        if not r or not h:\n            return None\n        return round(_wer(r, h), 4)\n    except Exception:\n        return None\n\nCOMMANDS = sorted({\n    'climb','descend','cleared','contact','squawk','maintain',\n    'turn','heading','hold','taxi','report','frequency',\n    'line up','approach','departure','inbound',\n})\n\nCMD_ALIASES = {\n    'cleared'   : ['cleared','cleare','clear'],\n    'approach'  : ['approach','appr','ils approach','mte approach'],\n    'departure' : ['departure','depart'],\n    'frequency' : ['frequency','freq'],\n    'line up'   : ['line up','lineup','line-up'],\n    'squawk'    : ['squawk','sqwk'],\n}\n\ndef cmd_in(cmd: str, text: str) -> int:\n    aliases = CMD_ALIASES.get(cmd, [cmd])\n    return int(any(a in text for a in aliases))\n\ndef cmd_vector(text: str) -> list[int]:\n    t = clean(text)\n    return [cmd_in(c, t) for c in COMMANDS]\n\nPHONETIC = {\n    'alpha':'a','alfa':'a','bravo':'b','charlie':'c','delta':'d',\n    'echo':'e','foxtrot':'f','golf':'g','hotel':'h','india':'i',\n    'juliet':'j','juliett':'j','kilo':'k','lima':'l','mike':'m',\n    'november':'n','oscar':'o','papa':'p','quebec':'q','romeo':'r',\n    'sierra':'s','tango':'t','uniform':'u','victor':'v','whiskey':'w',\n    'whisky':'w','xray':'x','x-ray':'x','yankee':'y','zulu':'z',\n}\nDIGIT = {\n    'zero':'0','one':'1','two':'2','three':'3','four':'4',\n    'five':'5','six':'6','seven':'7','eight':'8','nine':'9','niner':'9',\n}\n\ndef norm_cs(text: str) -> str:\n    out = []\n    for tok in text.lower().replace('-',' ').split():\n        if tok in PHONETIC:\n            out.append(PHONETIC[tok])\n        elif tok in DIGIT:\n            out.append(DIGIT[tok])\n        elif len(tok) == 1 and tok.isalnum():\n            out.append(tok)\n        else:\n    return ''.join(out)\n\nCS_PAT = re.compile(r'\\[#callsign\\](.*?)\\[/#callsign\\]', re.I)\n\ndef callsign_hit(gold_span: str, pred_text: str) -> int:\n    cs_n   = norm_cs(gold_span)\n    pred_n = norm_cs(clean(pred_text))\n    if cs_n and cs_n in pred_n:\n        return 1\n    if gold_span.strip().lower() in clean(pred_text):\n        return 1\n    target = cs_n or gold_span.strip().lower()\n    words  = pred_n.split() if cs_n else clean(pred_text).split()\n    tlen   = len(target.split()) if not cs_n else 1\n    best   = min(\n        (editdistance.eval(' '.join(words[i:i+tlen]), target)\n         for i in range(max(1, len(words)-tlen+1))),\n        default=float('inf')\n    )\n    return 1 if len(target) > 0 and best / len(target) < 0.3 else 0\n\ngold_cs_map = (\n    gold.groupby('file_key')['gold_text']\n    .apply(lambda txts: [s for t in txts for s in CS_PAT.findall(str(t))])\n    .to_dict()\n)\n\nrecords = []\nfor _, row in df.iterrows():\n    fk       = row['file_key']\n    gold_txt = row.get('gold_clean')\n    asr_txt  = str(row.get('asr_output', ''))\n    lev_txt  = str(row.get('lev_output', ''))\n    llm_txt  = str(row.get('llm_output', ''))\n    cs_spans = gold_cs_map.get(fk, [])\n\n    rec = {\n        'file_key' : fk,\n        'n_segs'   : int(row.get('n_segs', 1)),\n        'has_gold' : pd.notna(gold_txt),\n        'wer_asr'  : safe_wer(gold_txt, asr_txt) if pd.notna(gold_txt) else None,\n        'wer_lev'  : safe_wer(gold_txt, lev_txt)  if pd.notna(gold_txt) else None,\n        'wer_llm'  : safe_wer(gold_txt, llm_txt)  if pd.notna(gold_txt) else None,\n        'cmd_gold' : cmd_vector(gold_txt) if pd.notna(gold_txt) else None,\n        'cmd_asr'  : cmd_vector(asr_txt),\n        'cmd_lev'  : cmd_vector(lev_txt),\n        'cmd_llm'  : cmd_vector(llm_txt),\n        'cs_asr'   : [callsign_hit(s, asr_txt) for s in cs_spans],\n        'cs_lev'   : [callsign_hit(s, lev_txt)  for s in cs_spans],\n        'cs_llm'   : [callsign_hit(s, llm_txt)  for s in cs_spans],\n    }\n    records.append(rec)\n\navg = lambda lst: round(float(np.mean(lst)), 4) if lst else None\n\nwer_asr = avg([r['wer_asr'] for r in records if r['wer_asr'] is not None])\nwer_lev = avg([r['wer_lev'] for r in records if r['wer_lev'] is not None])\nwer_llm = avg([r['wer_llm'] for r in records if r['wer_llm'] is not None])\n\nct, ca, cl, cm = [], [], [], []\nfor r in records:\n    if r['cmd_gold']:\n        ct += r['cmd_gold']\n        ca += r['cmd_asr']\n        cl += r['cmd_lev']\n        cm += r['cmd_llm']\n\ndef f1(true, pred):\n    if not true:\n        return None\n    _, _, f, _ = precision_recall_fscore_support(\n        true, pred, average='binary', zero_division=0)\n    return round(float(f), 4)\n\nf1_asr = f1(ct, ca)\nf1_lev = f1(ct, cl)\nf1_llm = f1(ct, cm)\n\ncs_a = [h for r in records for h in r['cs_asr']]\ncs_l = [h for r in records for h in r['cs_lev']]\ncs_m = [h for r in records for h in r['cs_llm']]\ncs_acc = lambda hits: round(float(np.mean(hits)), 4) if hits else None\n\nn_gold = sum(r['has_gold'] for r in records)\nprint()\nprint('═'*62)\n      f'n={len(records)} files / gold={n_gold}')\nprint('═'*62)\nprint(f'{\"Metric\":34s} {\"ASR\":>8} {\"Lev\":>8} {\"LLM\":>8}')\nprint('─'*62)\n      f'{str(wer_asr):>8} {str(wer_lev):>8} {str(wer_llm):>8}')\nprint(f'{\"Command F1 ↑\":34s} '\n      f'{str(f1_asr):>8} {str(f1_lev):>8} {str(f1_llm):>8}')\nprint(f'{\"Callsign Acc. ↑\":34s} '\n      f'{str(cs_acc(cs_a)):>8} {str(cs_acc(cs_l)):>8} {str(cs_acc(cs_m)):>8}')\nprint('─'*62)\n\nprint()\nseg_wer = {}\nfor r in records:\n    if r['wer_llm'] is not None:\n        seg_wer.setdefault(r['n_segs'], []).append(r['wer_llm'])\nfor k in sorted(seg_wer):\n    print(f\"  seg={k}: {np.mean(seg_wer[k]):.4f}  (n={len(seg_wer[k])})\")\n\nprint()\nprint(f'{\"File\":42s} {\"WER_ASR\":>8} {\"WER_Lev\":>8} {\"WER_LLM\":>8} {\"Segs\":>5}')\nprint('─'*73)\nfor r in records:\n    na = lambda v: f'{v:.4f}' if v is not None else 'no gold'\n    print(f'{r[\"file_key\"][-42:]:42s} '\n          f'{na(r[\"wer_asr\"]):>8} {na(r[\"wer_lev\"]):>8} '\n          f'{na(r[\"wer_llm\"]):>8} {r[\"n_segs\"]:>5}')\n\nmetrics  = ['WER↓', 'Command\\nF1↑', 'Callsign\\nAcc.↑']\nasr_vals = [wer_asr or 0, f1_asr or 0, cs_acc(cs_a) or 0]\nlev_vals = [wer_lev or 0, f1_lev or 0, cs_acc(cs_l) or 0]\nllm_vals = [wer_llm or 0, f1_llm or 0, cs_acc(cs_m) or 0]\n\nx, bw = np.arange(len(metrics)), 0.25\nfig, ax = plt.subplots(figsize=(9, 5))\nb1 = ax.bar(x - bw, asr_vals, bw, label='ASR',              color='#E57373')\nb2 = ax.bar(x,       lev_vals, bw, label='Levenshtein RAG',  color='#64B5F6')\nb3 = ax.bar(x + bw,  llm_vals, bw, label='Slot+LLM RAG',    color='#81C784')\n\nax.set_xticks(x)\nax.set_xticklabels(metrics, fontsize=11)\nax.set_ylabel('Score')\nax.legend()\nax.set_ylim(0, 1.15)\n\nfor bar in list(b1) + list(b2) + list(b3):\n    h = bar.get_height()\n    if h > 0:\n        ax.text(bar.get_x() + bar.get_width()/2, h + 0.02,\n                f'{h:.3f}', ha='center', va='bottom', fontsize=8)\n\nplt.tight_layout()\nout_chart = f'eval_seg_concat_{datetime.now().strftime(\"%Y%m%d_%H%M%S\")}.png'\nplt.savefig(out_chart, dpi=150, bbox_inches='tight')\ntry:\n    from IPython.display import display, Image\n    plt.show()\n    display(Image(out_chart))\nexcept Exception:\n    pass\nprint(f'\\nChart saved: {out_chart}')\n\nout_df = pd.DataFrame([{\n    'file_key' : r['file_key'],\n    'n_segs'   : r['n_segs'],\n    'has_gold' : r['has_gold'],\n    'wer_asr'  : r['wer_asr'],\n    'wer_lev'  : r['wer_lev'],\n    'wer_llm'  : r['wer_llm'],\n    'cs_asr'   : int(np.mean(r['cs_asr'])) if r['cs_asr'] else None,\n    'cs_lev'   : int(np.mean(r['cs_lev'])) if r['cs_lev'] else None,\n    'cs_llm'   : int(np.mean(r['cs_llm'])) if r['cs_llm'] else None,\n} for r in records])\n\nout_csv = f'eval_seg_concat_{datetime.now().strftime(\"%Y%m%d_%H%M%S\")}.csv'\nout_df.to_csv(out_csv, index=False, encoding='utf-8-sig')\nprint(f'CSV  saved: {out_csv}')\nprint(f'Rows: {len(out_df)}')"
